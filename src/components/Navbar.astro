---
import { navLinks } from "../data/site";

const currentPath = Astro.url.pathname;
---

<nav class="bsa-navbar" id="navbar">
  <div class="container bsa-nav-inner">
    <a href="/" class="bsa-nav-logo">
      <img src="/images/logo.jpg" alt="UT BSA Logo" class="bsa-nav-logo-img" />
      <span class="bsa-logo-text">UT BSA</span>
    </a>

    <!-- Desktop links -->
    <ul class="bsa-nav-desktop">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["bsa-nav-link", { "bsa-nav-active": currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Hamburger button -->
    <button class="bsa-hamburger" id="nav-toggle" aria-label="Toggle menu">
      <span class="bsa-hamburger-line"></span>
      <span class="bsa-hamburger-line"></span>
      <span class="bsa-hamburger-line"></span>
    </button>
  </div>
</nav>

<!-- Mobile menu (completely separate from nav) -->
<div class="bsa-mobile-menu" id="mobile-menu" style="display:none;">
  <ul>
    {navLinks.map((link) => (
      <li>
        <a href={link.href} class="bsa-mobile-link">{link.label}</a>
      </li>
    ))}
  </ul>
</div>

<style is:global>
  .bsa-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--gray-200);
    transition: all 300ms ease;
  }

  .bsa-navbar.scrolled {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .bsa-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .bsa-nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    z-index: 1001;
    text-decoration: none;
  }

  .bsa-nav-logo-img {
    height: 44px;
    width: auto;
    border-radius: 6px;
  }

  .bsa-logo-text {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: 0.02em;
  }

  /* Desktop nav */
  .bsa-nav-desktop {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bsa-nav-link {
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray-600);
    border-radius: 8px;
    transition: all 150ms ease;
    text-decoration: none;
  }

  .bsa-nav-link:hover {
    color: var(--blue);
    background: var(--gray-50);
  }

  .bsa-nav-active {
    color: var(--blue) !important;
    font-weight: 600;
    background: rgba(0, 62, 126, 0.06);
  }

  /* Hamburger */
  .bsa-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    z-index: 1001;
    cursor: pointer;
    border: none;
    background: none;
  }

  .bsa-hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: #1A1A1A;
    border-radius: 2px;
    transition: all 300ms ease;
  }

  /* Mobile menu - fullscreen overlay */
  .bsa-mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
    background: #FFFFFF;
  }

  .bsa-mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 0.5rem;
  }

  .bsa-mobile-link {
    display: block;
    padding: 0.75rem 2rem;
    font-size: 1.5rem;
    font-weight: 600;
    color: #1A1A1A;
    text-decoration: none;
    border-radius: 8px;
  }

  .bsa-mobile-link:hover {
    color: var(--blue);
  }

  @media (max-width: 768px) {
    .bsa-nav-desktop {
      display: none !important;
    }

    .bsa-hamburger {
      display: flex !important;
    }
  }

  @media (min-width: 769px) {
    .bsa-mobile-menu {
      display: none !important;
    }
  }
</style>

<script>
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar?.classList.add("scrolled");
    } else {
      navbar?.classList.remove("scrolled");
    }
  });

  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    if (menu) {
      const isOpen = menu.style.display === "block";
      menu.style.display = isOpen ? "none" : "block";
    }
  });

  // Close menu on link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (menu) menu.style.display = "none";
    });
  });
</script>
