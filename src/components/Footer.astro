---
import { siteConfig, navLinks } from "../data/site";
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/images/logo.jpg" alt="UT BSA Logo" class="footer-logo-img" />
          <span class="logo-text">UT BSA</span>
        </div>
        <p>{siteConfig.description}</p>
      </div>

      <div class="footer-links">
        <h4>Navigation</h4>
        <ul>
          {navLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Connect</h4>
        <ul>
          <li><a href={siteConfig.socials.instagram} target="_blank" rel="noopener">Instagram</a></li>
          <li><a href={siteConfig.socials.facebook} target="_blank" rel="noopener">Facebook</a></li>
          <li><a href={siteConfig.socials.invonet} target="_blank" rel="noopener">InvoNet</a></li>
          <li><a href={`mailto:${siteConfig.socials.email}`}>{siteConfig.socials.email}</a></li>
        </ul>
        <h4 style="margin-top: 1.5rem;">Address</h4>
        <p style="font-size: 0.85rem; color: rgba(255,255,255,0.7);">{siteConfig.address}</p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {siteConfig.fullName} &mdash; {siteConfig.university}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--gray-200);
    padding: 4rem 0 2rem;
    background: var(--blue);
    color: white;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    height: 40px;
    width: auto;
    border-radius: 6px;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--gold);
  }

  .footer-brand p {
    font-size: 0.9rem;
    max-width: 350px;
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-links h4,
  .footer-contact h4 {
    color: var(--gold);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
  }

  .footer-links ul,
  .footer-contact ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a,
  .footer-contact a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover,
  .footer-contact a:hover {
    color: var(--gold);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 2rem;
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
