---
import Layout from "../layouts/Layout.astro";
import FadeIn from "../components/react/FadeIn";
import { alumniMembers } from "../data/site";
---

<Layout title="Alumni" description="The BSA Wall of Fame — UToledo BSA graduates making an impact worldwide">
  <section class="page-hero">
    <div class="container">
      <FadeIn client:load>
        <p class="page-label">Legacy</p>
        <h1>Wall of <span class="text-blue">Fame</span></h1>
        <p class="page-subtitle">BSA alumni making an impact at top companies around the world.</p>
      </FadeIn>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="alumni-grid">
        {alumniMembers.map((alum, i) => (
          <FadeIn client:load delay={i * 0.08}>
            <div class="card alumni-card">
              <div class="alumni-image">
                <img src={alum.image} alt={alum.name} />
              </div>
              <div class="alumni-info">
                <h3>{alum.name}</h3>
                <p class="alumni-role">{alum.role}</p>
                <span class="company-badge">{alum.company}</span>
                <p class="alumni-year">Class of {alum.graduationYear}</p>
              </div>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: calc(var(--nav-height) + 4rem) 2rem 2rem;
    text-align: center;
    background: var(--off-white);
    border-bottom: 1px solid var(--gray-200);
  }

  .page-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold-dark);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .page-hero h1 {
    margin-bottom: 0.75rem;
  }

  .page-subtitle {
    max-width: 520px;
    margin: 0 auto;
  }

  .alumni-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
    gap: 1.5rem;
  }

  .alumni-card {
    text-align: center;
    overflow: hidden;
  }

  .alumni-image {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--gray-100);
  }

  .alumni-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .alumni-info {
    padding: 1.25rem;
  }

  .alumni-info h3 {
    font-size: 1.05rem;
    margin-bottom: 0.2rem;
  }

  .alumni-role {
    font-size: 0.85rem !important;
    margin-bottom: 0.75rem;
  }

  .company-badge {
    display: inline-block;
    background: rgba(0, 62, 126, 0.08);
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    border: 1px solid rgba(0, 62, 126, 0.12);
  }

  .alumni-year {
    font-size: 0.78rem !important;
    color: var(--gray-500) !important;
    margin-top: 0.6rem;
  }

  @media (max-width: 768px) {
    .alumni-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .alumni-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
