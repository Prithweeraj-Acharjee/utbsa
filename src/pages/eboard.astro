---
import Layout from "../layouts/Layout.astro";
import FadeIn from "../components/react/FadeIn";
import { eboardMembers, eboardMembers2024 } from "../data/site";

const president = eboardMembers[0];
const vps = eboardMembers.slice(1, 3);
const rest = eboardMembers.slice(3);
---

<Layout title="E-Board" description="Meet the executive board of the Bangladeshi Student Association at UToledo">
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <FadeIn client:load>
        <p class="page-label">Our Team</p>
        <h1>Executive <span class="text-blue">Board</span></h1>
        <p class="page-subtitle">The passionate leaders behind BSA — dedicated to building community, celebrating Bangladeshi culture, and empowering every member at the University of Toledo.</p>
      </FadeIn>
    </div>
  </section>

  <!-- Year banner -->
  <section class="year-banner">
    <div class="container">
      <span class="year-tag">2025 – 2026</span>
    </div>
  </section>

  <!-- President — featured large -->
  <section class="section president-section">
    <div class="container">
      <FadeIn client:load>
        <div class="president-card">
          <div class="president-image">
            <img src={president.image} alt={president.name} />
          </div>
          <div class="president-info">
            <span class="role-badge">{president.title}</span>
            <h2 class="president-name">{president.name}</h2>
            <p class="president-major">{president.major}</p>
            <div class="role-divider"></div>
            <p class="role-desc">{president.role}</p>
          </div>
        </div>
      </FadeIn>
    </div>
  </section>

  <!-- Vice Presidents — side by side -->
  <section class="section vp-section">
    <div class="container">
      <div class="vp-grid">
        {vps.map((member, i) => (
          <FadeIn client:load delay={i * 0.1}>
            <div class="vp-card">
              <div class="vp-image">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="vp-info">
                <span class="role-badge">{member.title}</span>
                <h3>{member.name}</h3>
                <p class="member-major">{member.major}</p>
                <div class="role-divider"></div>
                <p class="role-desc">{member.role}</p>
              </div>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- Remaining members -->
  <section class="section members-section">
    <div class="container">
      <div class="members-grid">
        {rest.map((member, i) => (
          <FadeIn client:load delay={i * 0.06}>
            <div class="member-card">
              <div class="member-image">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="member-info">
                <span class="role-badge small">{member.title}</span>
                <h3>{member.name}</h3>
                <p class="member-major">{member.major}</p>
                <div class="role-divider"></div>
                <p class="role-desc">{member.role}</p>
              </div>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- 2024-25 Past Board -->
  <section class="section past-board">
    <div class="container">
      <FadeIn client:load>
        <div class="section-header">
          <p class="page-label">Previous Leadership</p>
          <h2>2024–25 <span class="accent">E-Board</span></h2>
        </div>
      </FadeIn>
      <div class="past-grid">
        {eboardMembers2024.map((member, i) => (
          <FadeIn client:load delay={i * 0.06}>
            <div class="past-card">
              <div class="past-image">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="past-info">
                <h4>{member.name}</h4>
                <span class="past-title">{member.title}</span>
              </div>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .page-hero {
    padding: calc(var(--nav-height) + 4rem) 2rem 2rem;
    text-align: center;
    background: var(--off-white);
    border-bottom: 1px solid var(--gray-200);
  }

  .page-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold-dark);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .page-hero h1 {
    margin-bottom: 0.75rem;
  }

  .page-subtitle {
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Year banner */
  .year-banner {
    background: var(--blue);
    padding: 0.75rem 2rem;
    text-align: center;
  }

  .year-tag {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  /* Common elements */
  .role-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    color: white;
    background: var(--blue);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .role-badge.small {
    font-size: 0.65rem;
    padding: 0.25rem 0.65rem;
  }

  .role-divider {
    width: 40px;
    height: 2px;
    background: var(--gold);
    margin: 0.75rem 0;
  }

  .role-desc {
    font-size: 0.85rem !important;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .member-major {
    font-size: 0.82rem !important;
    color: var(--text-secondary);
    font-style: italic;
  }

  /* President section */
  .president-section {
    padding-top: 3rem;
  }

  .president-card {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 3rem;
    align-items: center;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid var(--gray-200);
  }

  .president-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .president-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .president-info {
    padding: 2.5rem 2.5rem 2.5rem 0;
  }

  .president-name {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .president-major {
    font-size: 0.9rem !important;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 0.5rem;
  }

  /* VP section */
  .vp-section {
    background: var(--off-white);
  }

  .vp-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .vp-card {
    display: grid;
    grid-template-columns: 260px 1fr;
    background: white;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.05);
    border: 1px solid var(--gray-200);
    height: 100%;
  }

  .vp-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .vp-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vp-info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .vp-info h3 {
    font-size: 1.4rem;
    margin-bottom: 0.2rem;
  }

  /* Remaining members */
  .members-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .member-card {
    background: white;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.05);
    border: 1px solid var(--gray-200);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .member-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .member-image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--gray-100);
  }

  .member-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .member-info {
    padding: 1.25rem;
  }

  .member-info h3 {
    font-size: 1.2rem;
    margin-bottom: 0.15rem;
  }

  /* Past board */
  .past-board {
    background: var(--off-white);
  }

  .section-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .past-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .past-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    border: 1px solid var(--gray-200);
    text-align: center;
  }

  .past-image {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--gray-100);
  }

  .past-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .past-info {
    padding: 1rem;
  }

  .past-info h4 {
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
  }

  .past-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Mobile responsive */
  @media (max-width: 1024px) {
    .members-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .president-card {
      grid-template-columns: 1fr;
    }

    .president-info {
      padding: 1.5rem;
    }

    .president-image {
      aspect-ratio: 4 / 3;
    }

    .vp-grid {
      grid-template-columns: 1fr;
    }

    .vp-card {
      grid-template-columns: 1fr;
    }

    .vp-image {
      aspect-ratio: 4 / 3;
    }

    .members-grid {
      grid-template-columns: 1fr;
    }

    .past-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
