---
import Layout from "../layouts/Layout.astro";
import FadeIn from "../components/react/FadeIn";
import { eboardMembers, eboardMembers2024 } from "../data/site";
---

<Layout title="E-Board" description="Meet the executive board of the Bangladeshi Student Association at UToledo">
  <section class="page-hero">
    <div class="container">
      <FadeIn client:load>
        <p class="page-label">Leadership</p>
        <h1>Meet the <span class="text-blue">E-Board</span></h1>
        <p class="page-subtitle">The leaders who keep BSA running — dedicated to building community and celebrating Bangladeshi culture at UToledo.</p>
      </FadeIn>
    </div>
  </section>

  <!-- 2025-26 E-Board -->
  <section class="section">
    <div class="container">
      <FadeIn client:load>
        <div class="section-header">
          <h2>2025–26 <span class="accent">E-Board</span></h2>
        </div>
      </FadeIn>
      <div class="eboard-grid">
        {eboardMembers.map((member, i) => (
          <FadeIn client:load delay={i * 0.08}>
            <div class="card member-card">
              <div class="member-image">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="member-info">
                <h3>{member.name}</h3>
                <span class="member-title">{member.title}</span>
                <p class="member-major">{member.major}</p>
              </div>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- 2024-25 E-Board -->
  <section class="section past-board">
    <div class="container">
      <FadeIn client:load>
        <div class="section-header">
          <h2>2024–25 <span class="accent">E-Board</span></h2>
        </div>
      </FadeIn>
      <div class="eboard-grid">
        {eboardMembers2024.map((member, i) => (
          <FadeIn client:load delay={i * 0.08}>
            <div class="card member-card">
              <div class="member-image">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="member-info">
                <h3>{member.name}</h3>
                <span class="member-title">{member.title}</span>
              </div>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: calc(var(--nav-height) + 4rem) 2rem 2rem;
    text-align: center;
    background: var(--off-white);
    border-bottom: 1px solid var(--gray-200);
  }

  .page-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold-dark);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .page-hero h1 {
    margin-bottom: 0.75rem;
  }

  .page-subtitle {
    max-width: 520px;
    margin: 0 auto;
  }

  .eboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 2rem;
  }

  .member-card {
    overflow: hidden;
  }

  .member-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--gray-100);
  }

  .member-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .member-info {
    padding: 1.5rem;
  }

  .member-info h3 {
    margin-bottom: 0.25rem;
  }

  .member-title {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .member-major {
    font-size: 0.88rem !important;
    color: var(--text-secondary);
  }

  .past-board {
    background: var(--off-white);
  }

  @media (max-width: 768px) {
    .eboard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
